<!-- main frontend page for edgeurl, handles user input and ajax-based url shortening -->

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>EdgeURL</title>
  <link rel="stylesheet" href="/css/styles.css" />
</head>
<body>
  <div class="background-glow glow-1"></div>
  <div class="background-glow glow-2"></div>

  <main class="container">
    <section class="card">
      <h1>EdgeURL</h1>
      <p class="subtitle">Shorten your links instantly.</p>

      <!-- form for submitting a url to be shortened -->
      <form id="urlForm" class="url-form">
        <input
          type="text"
          name="originalUrl"
          placeholder="Enter URL..."
          required
        />
        <button type="submit">Shorten</button>
      </form>

      <!-- displays result or error messages -->
      <div id="result" class="result-box" style="display: none;"></div>

      <!-- link to logs page -->
      <a href="/logs" class="secondary-button logs-button">View Logs</a>
    </section>
  </main>

  <script>
    const form = document.getElementById('urlForm');
    const resultDiv = document.getElementById('result');
    const input = form.querySelector('input[name="originalUrl"]');
    const button = form.querySelector('button');

    // handles form submission using ajax instead of page reload
    form.addEventListener('submit', async (e) => {
      e.preventDefault();

      const formData = new FormData(form);
      const originalUrl = formData.get('originalUrl');

      try {
        const response = await fetch('/shorten', {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json'
          },
          body: JSON.stringify({ originalUrl })
        });

        const data = await response.json();

        resultDiv.style.display = 'block';

        // handles rate limit response with countdown until retry
        if (response.status === 429) {
          let secondsLeft = data.retryAfterSeconds || 60;

          input.disabled = true;
          button.disabled = true;

          resultDiv.innerHTML = `
            <p>${data.error}</p>
            <p>Page will reset in ${secondsLeft} seconds...</p>
          `;

          const countdown = setInterval(() => {
            secondsLeft--;

            resultDiv.innerHTML = `
              <p>${data.error}</p>
              <p>Try again in ${secondsLeft} seconds...</p>
            `;

            if (secondsLeft <= 0) {
              clearInterval(countdown);
              form.reset();
              resultDiv.style.display = 'none';
              resultDiv.innerHTML = '';
              input.disabled = false;
              button.disabled = false;
            }
          }, 1000);

          return;
        }

        // displays validation error from backend
        if (data.error) {
          resultDiv.innerHTML = `<p>${data.error}</p>`;
        } else {
          // displays shortened url (or reused existing one)
          resultDiv.innerHTML = `
            <p>${data.reused ? 'Existing short URL found:' : 'URL created:'}</p>
            <a href="${data.shortUrl}" target="_blank">${data.shortUrl}</a>
          `;
        }

      } catch (err) {
        resultDiv.style.display = 'block';
        resultDiv.innerHTML = `<p>Something went wrong</p>`;
      }
    });
  </script>
</body>
</html>